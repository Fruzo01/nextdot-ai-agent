import textwrap  # ← you were missing this

def print_result(title, result):
    print(f"\n================ {title} ================")

    print("\n🔹 Intent & Sentiment")
    print(f"  → Intent    : {result['intent']}")
    print(f"  → Sentiment : {result['sentiment']}")

    print("\n🔹 Extracted Info")
    for k, v in result["extracted"].items():
        print(f"  → {k.replace('_',' ').title():<18}: {v}")

    print("\n🔹 Reply")
    print(textwrap.fill(result["reply"], width=70))

    print("\n🔹 Reasoning")
    print(textwrap.fill(result["reasoning"], width=70))

    print("========================================")


